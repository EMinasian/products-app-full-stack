
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Comment {
  commentId Int @default(autoincrement()) @id
  title String
  autorId Int
}

model User {
  id Int @default(autoincrement()) @id
  firstname String
  lastname String
  username String @unique
  email String @unique
  profilePictureUrl String?
  password String
  products Product[]
}

model Product {
  id Int @default(autoincrement()) @id
  name String
  description String
  price Float
  userId Int
  user User @relation(fields: [userId], references: [id]) 
  sold Boolean @default(false)
}